@page "{id:int}"
@model PosCorte.Web.Pages.Projetos.SucessoModel
@{
    ViewData["Title"] = "Pagamento confirmado";
}

<div class="container py-5">
    <div class="pc-card mx-auto" style="max-width:560px">
        <div class="pc-card-body pc-success-hero">
            <div class="icon-ring"><i class="bi bi-check-lg"></i></div>
            <h1 class="h3 fw-bold mb-2">Pagamento confirmado!</h1>
            <p class="text-muted mb-4">
                O valor está em <strong>escrow</strong>. Estamos alocando um montador homologado para
                <strong>@Model.Projeto?.NomeProjeto</strong>. Você recebe atualização por e-mail/WhatsApp.
            </p>
            <div class="pc-alert pc-alert-info text-start mb-4">
                <strong>Próximos passos:</strong>
                <ol class="small mb-0 mt-2 ps-3">
                    <li>Montador confirmado (meta: até 24h)</li>
                    <li>Montagem na obra</li>
                    <li>Você vistoria e aprova → pagamento liberado</li>
                </ol>
            </div>
            <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
                <a asp-page="/Projetos/Detalhes" asp-route-id="@Model.Projeto!.Id" class="btn btn-pc-primary">
                    Acompanhar projeto <i class="bi bi-arrow-right ms-1"></i>
                </a>
                <a asp-page="/Projetos/Criar" class="btn btn-pc-ghost">Novo projeto</a>
            </div>
        </div>
    </div>
</div>

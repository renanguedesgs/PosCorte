@page
@model ErrorModel
@{
    ViewData["Title"] = "Algo deu errado";
}

<div class="container py-5">
    <div class="pc-card mx-auto" style="max-width:560px">
        <div class="pc-card-body text-center py-5">
            <div class="pc-feature-icon mx-auto" style="background:var(--pc-danger-soft);color:var(--pc-danger)">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <h1 class="h3 fw-bold mt-2">Algo deu errado</h1>
            <p class="text-muted">Tivemos um problema ao processar sua solicitação. Tente novamente em instantes.</p>

            @if (Model.ShowRequestId)
            {
                <p class="small text-muted">Código do erro: <code>@Model.RequestId</code></p>
            }

            <div class="d-flex justify-content-center gap-2 mt-3">
                <a asp-page="/Index" class="btn btn-pc-ghost">Voltar ao início</a>
                <a asp-page="/Dashboard" class="btn btn-pc-primary">Ir ao painel</a>
            </div>
        </div>
    </div>
</div>

@page
@model PosCorte.Web.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Entrar";
}

<div class="pc-auth-wrap">
    <div class="pc-auth-card">
            <div class="text-center mb-4">
                @{
                    ViewData["BrandExtraClass"] = "justify-content-center mb-2 d-inline-flex";
                    ViewData["BrandFooter"] = false;
                    ViewData["BrandAuth"] = true;
                    ViewData["BrandLink"] = true;
                }
                <partial name="_Brand" />
            <h1 class="h3 fw-bold mb-1">Bem-vindo de volta</h1>
            <p class="text-muted mb-0">Acesse sua central de projetos</p>
        </div>

        <div class="pc-card">
            <div class="pc-card-body">
                @if (!string.IsNullOrEmpty(Model.Erro))
                {
                    <div class="pc-alert pc-alert-danger mb-3"><i class="bi bi-exclamation-circle me-1"></i>@Model.Erro</div>
                }
                @if (!string.IsNullOrEmpty(Model.Sucesso))
                {
                    <div class="pc-alert pc-alert-success mb-3"><i class="bi bi-check-circle me-1"></i>@Model.Sucesso</div>
                }

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">E-mail</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="voce@escritorio.com" autofocus />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Senha</label>
                        <input asp-for="Senha" class="form-control" type="password" placeholder="••••••••" />
                    </div>
                    <button type="submit" class="btn btn-pc-primary w-100">Entrar <i class="bi bi-arrow-right ms-1"></i></button>
                </form>
            </div>
        </div>

        <p class="text-center text-muted mt-4 mb-0">
            Ainda não tem conta? <a asp-page="/Auth/Register" class="fw-semibold">Criar conta grátis</a>
        </p>
    </div>
</div>

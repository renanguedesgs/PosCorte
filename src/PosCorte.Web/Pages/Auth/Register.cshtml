@page
@model PosCorte.Web.Pages.Auth.RegisterModel
@{
    ViewData["Title"] = "Criar conta";
}

<div class="pc-auth-wrap">
    <div class="pc-auth-card">
        <div class="text-center mb-4">
            @{
                ViewData["BrandExtraClass"] = "justify-content-center mb-2 d-inline-flex";
                ViewData["BrandFooter"] = false;
                ViewData["BrandAuth"] = true;
                ViewData["BrandLink"] = true;
            }
            <partial name="_Brand" />
            <h1 class="h3 fw-bold mb-1">Crie sua conta grátis</h1>
            <p class="text-muted mb-0">Comece a despachar montagens com garantia hoje</p>
        </div>

        <div class="pc-card">
            <div class="pc-card-body">
                @if (!string.IsNullOrEmpty(Model.Erro))
                {
                    <div class="pc-alert pc-alert-danger mb-3"><i class="bi bi-exclamation-circle me-1"></i>@Model.Erro</div>
                }

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Nome completo / Escritório</label>
                        <input asp-for="Nome" class="form-control" placeholder="Studio Arquitetura" autofocus />
                    </div>
                    <div class="row g-3">
                        <div class="col-md-7 mb-3">
                            <label class="form-label">E-mail</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="voce@escritorio.com" />
                        </div>
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Telefone</label>
                            <input asp-for="Telefone" class="form-control" placeholder="11999999999" />
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-7 mb-3">
                            <label class="form-label">CPF / CNPJ</label>
                            <input asp-for="CpfCnpj" class="form-control" placeholder="Somente números" />
                        </div>
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Senha</label>
                            <input asp-for="Senha" class="form-control" type="password" placeholder="Mín. 6 caracteres" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-pc-primary w-100">Criar conta <i class="bi bi-arrow-right ms-1"></i></button>
                    <p class="small text-muted text-center mt-3 mb-0">
                        Ao criar conta, você concorda com os <a asp-page="/Legal/Termos">Termos</a> e a <a asp-page="/Legal/Privacidade">Privacidade</a>.
                    </p>
                </form>
            </div>
        </div>

        <p class="text-center text-muted mt-4 mb-0">
            Já tem conta? <a asp-page="/Auth/Login" class="fw-semibold">Entrar</a>
        </p>
    </div>
</div>

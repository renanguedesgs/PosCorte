@using System.Security.Claims
@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · PósCorte</title>
    <link rel="icon" type="image/png" href="~/favicon.png" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/images/poscorte-icon.png" asp-append-version="true" />
    <meta name="theme-color" content="#1B5E4B" />
    <link rel="manifest" href="/manifest.json" />
    <partial name="_Seo" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Inter:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="@(User.Identity?.IsAuthenticated == true ? "pc-layout-app" : "pc-layout-public")">
    <header>
        <nav class="navbar navbar-expand-lg pc-navbar">
            <div class="container">
                @{
                    ViewData["BrandExtraClass"] = "navbar-brand";
                    ViewData["BrandFooter"] = false;
                    ViewData["BrandAuth"] = false;
                    ViewData["BrandLink"] = true;
                }
                <partial name="_Brand" />
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse align-items-center" id="navMain">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Admin"))
                        {
                            <ul class="navbar-nav me-auto ms-lg-4">
                                <li class="nav-item"><a class="nav-link" asp-page="/Admin/Index"><i class="bi bi-speedometer2 me-1"></i>Painel Admin</a></li>
                                <li class="nav-item"><a class="nav-link" asp-page="/Admin/Financeiro"><i class="bi bi-cash-stack me-1"></i>Financeiro</a></li>
                                <li class="nav-item"><a class="nav-link" asp-page="/Admin/Projetos"><i class="bi bi-folder me-1"></i>Projetos</a></li>
                                <li class="nav-item"><a class="nav-link" asp-page="/Admin/Arquitetos"><i class="bi bi-people me-1"></i>Arquitetos</a></li>
                                <li class="nav-item"><a class="nav-link" asp-page="/Admin/Marceneiros"><i class="bi bi-person-badge me-1"></i>Montadores</a></li>
                            </ul>
                        }
                        else
                        {
                            <div class="pc-nav-pill me-lg-auto">
                                <ul class="navbar-nav">
                                    <li class="nav-item"><a class="nav-link" asp-page="/Dashboard"><i class="bi bi-grid-1x2 me-1"></i>Dashboard</a></li>
                                    <li class="nav-item"><a class="nav-link" asp-page="/Projetos/Index"><i class="bi bi-folder me-1"></i>Projetos</a></li>
                                    <li class="nav-item"><a class="nav-link" asp-page="/Ordens/Index"><i class="bi bi-truck me-1"></i>Ordens</a></li>
                                </ul>
                            </div>
                            <a class="btn btn-pc-primary btn-sm me-3 ms-lg-2" asp-page="/Projetos/Criar"><i class="bi bi-plus-lg me-1"></i>Novo projeto</a>
                        }
                        <div class="d-flex align-items-center gap-3 ms-auto">
                            @if (User.IsInRole("Admin"))
                            {
                                <span class="badge bg-dark">Admin</span>
                            }
                            <div class="dropdown">
                                <a class="d-flex align-items-center gap-2 text-decoration-none dropdown-toggle" data-bs-toggle="dropdown" role="button">
                                    <span class="pc-avatar">@(User.Identity!.Name?.Substring(0, 1).ToUpper() ?? "U")</span>
                                    <span class="d-none d-lg-inline fw-semibold text-dark">@(User.Identity!.Name ?? "Conta")</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                    <li><span class="dropdown-item-text small text-muted">@User.FindFirstValue(ClaimTypes.Email)</span></li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><a class="dropdown-item" asp-page="/Admin/Conta"><i class="bi bi-key me-2"></i>Trocar senha</a></li>
                                    }
                                    else
                                    {
                                        <li><a class="dropdown-item" asp-page="/Conta/Perfil"><i class="bi bi-person me-2"></i>Meu perfil</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-page="/Auth/Logout"><i class="bi bi-box-arrow-right me-2"></i>Sair</a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    }
                    else
                    {
                        <ul class="navbar-nav me-auto ms-lg-4">
                            <li class="nav-item"><a class="nav-link" href="/#como-funciona">Como funciona</a></li>
                            <li class="nav-item"><a class="nav-link" href="/#corte-cloud">Corte Cloud</a></li>
                            <li class="nav-item"><a class="nav-link" href="/#precos">Preços</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Marceneiros/Seja"><i class="bi bi-hammer me-1"></i>Seja um montador</a></li>
                        </ul>
                        <div class="d-flex align-items-center gap-2">
                            <a class="btn btn-pc-ghost btn-sm" asp-page="/Auth/Login">Entrar</a>
                            <a class="btn btn-pc-primary btn-sm" asp-page="/Auth/Register">Criar conta grátis</a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="pc-footer">
        <div class="container">
            <div class="row g-4 mb-4">
                <div class="col-md-4">
                    @{
                        ViewData["BrandExtraClass"] = "";
                        ViewData["BrandFooter"] = true;
                        ViewData["BrandLink"] = false;
                    }
                    <partial name="_Brand" />
                    <p class="small text-white-50 mt-3 mb-0">A ponte entre o corte do MDF e a montagem garantida. Orçamento na hora, escrow e montador homologado.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white fw-bold mb-3">Para arquitetos</h6>
                    <div class="d-flex flex-column gap-2 small">
                        <a href="/#como-funciona" class="text-white-50 text-decoration-none">Como funciona</a>
                        <a href="/#precos" class="text-white-50 text-decoration-none">Preços transparentes</a>
                        <a asp-page="/Auth/Register" class="text-white-50 text-decoration-none">Criar conta grátis</a>
                    </div>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white fw-bold mb-3">Para montadores</h6>
                    <div class="d-flex flex-column gap-2 small">
                        <a asp-page="/Marceneiros/Seja" class="text-white-50 text-decoration-none">Seja um montador</a>
                        <a asp-page="/Legal/Termos" class="text-white-50 text-decoration-none">Termos de uso</a>
                        <a asp-page="/Legal/Privacidade" class="text-white-50 text-decoration-none">Privacidade</a>
                    </div>
                </div>
            </div>
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 border-top border-secondary pt-3">
                <span class="text-white-50 small">© 2026 PósCorte · Grande São Paulo</span>
                <div class="d-flex flex-wrap align-items-center gap-3 small text-white-50">
                    <span><i class="bi bi-shield-lock me-1"></i>Escrow</span>
                    <span><i class="bi bi-patch-check me-1"></i>Montador homologado</span>
                    <span><i class="bi bi-lightning-charge me-1"></i>Orçamento em 30s</span>
                </div>
            </div>
        </div>
    </footer>

    @if (User.Identity?.IsAuthenticated != true && Context.Request.Path == "/")
    {
        <div class="pc-sticky-cta" id="stickyCta" hidden>
            <div class="container d-flex align-items-center justify-content-between gap-2">
                <span class="small fw-semibold text-white">Montagem com garantia hoje</span>
                <a asp-page="/Auth/Register" class="btn btn-pc-accent btn-sm">Criar conta grátis</a>
            </div>
        </div>
    }

    @{
        var waNum = Configuration["Site:WhatsAppNumber"];
        if (!string.IsNullOrWhiteSpace(waNum))
        {
            var waMsg = Uri.EscapeDataString("Olá! Quero saber mais sobre o PósCorte para montagem de planejados.");
            <a class="pc-whatsapp-float" href="https://wa.me/@waNum?text=@waMsg" target="_blank" rel="noopener" aria-label="WhatsApp suporte">
                <i class="bi bi-whatsapp"></i>
            </a>
        }
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/premium-ui.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

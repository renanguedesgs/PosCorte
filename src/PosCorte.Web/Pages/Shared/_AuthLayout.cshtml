<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · PósCorte</title>
    <link rel="icon" type="image/png" href="~/favicon.png" asp-append-version="true" />
    <meta name="theme-color" content="#1B5E4B" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Inter:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="pc-auth-body">
    <div class="pc-auth-split">
        <aside class="pc-auth-hero" aria-hidden="true">
            <canvas class="pc-hero-mesh-canvas" aria-hidden="true"></canvas>
            <div class="pc-hero-grid-lines" aria-hidden="true"></div>
            <div class="pc-auth-hero-inner">
                @{
                    ViewData["BrandExtraClass"] = "pc-auth-brand";
                    ViewData["BrandFooter"] = false;
                    ViewData["BrandAuth"] = true;
                    ViewData["BrandLink"] = false;
                }
                <partial name="_Brand" />
                <h2 class="pc-auth-hero-title">Montagem de planejados com escrow e montador homologado</h2>
                <p class="pc-auth-hero-lead">Orçamento em 30 segundos. Você paga com PIX, o montador só recebe após sua aprovação.</p>
                <ul class="pc-auth-hero-list">
                    <li><i class="bi bi-lightning-charge-fill"></i> Orçamento instantâneo via Corte Cloud</li>
                    <li><i class="bi bi-shield-lock-fill"></i> Pagamento em escrow — zero calote</li>
                    <li><i class="bi bi-patch-check-fill"></i> Montadores verificados na Grande SP</li>
                    <li><i class="bi bi-clock-fill"></i> Alocação automática em até 24h</li>
                </ul>
                <div class="pc-auth-hero-stats">
                    <div><strong>700+</strong><span>montagens</span></div>
                    <div><strong>98%</strong><span>satisfação</span></div>
                    <div><strong>24h</strong><span>alocação</span></div>
                </div>
            </div>
            <div class="pc-auth-hero-glow"></div>
        </aside>
        <main class="pc-auth-main">
            <div class="pc-auth-main-top">
                <a href="/" class="pc-auth-home-link"><i class="bi bi-arrow-left me-1"></i>Início</a>
            </div>
            <div class="pc-auth-form-wrap">
                @RenderBody()
            </div>
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/hero-mesh.js" asp-append-version="true"></script>
    <script src="~/js/premium-ui.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

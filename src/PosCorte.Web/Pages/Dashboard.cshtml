@page
@model PosCorte.Web.Pages.DashboardModel
@using PosCorte.Web.Services
@{
    ViewData["Title"] = "Dashboard";
    var primeiroNome = Model.NomeUsuario.Split(' ').FirstOrDefault() ?? Model.NomeUsuario;
}

<div class="container py-4">
    <div class="pc-page-header d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
            <span class="pc-eyebrow">Central do arquiteto</span>
            <h1>Olá, @primeiroNome</h1>
        </div>
        <a asp-page="/Projetos/Criar" class="btn btn-pc-primary"><i class="bi bi-plus-lg me-1"></i>Novo projeto</a>
    </div>

    @if (Model.Onboarding)
    {
        <div class="pc-onboard">
            <h5 class="fw-bold mb-3"><i class="bi bi-rocket-takeoff me-2"></i>Comece em 3 passos</h5>
            <div class="check-item">
                <span class="ico"><i class="bi bi-1-circle"></i></span>
                <span>Crie seu primeiro projeto com link do Corte Cloud</span>
            </div>
            <div class="check-item">
                <span class="ico"><i class="bi bi-2-circle"></i></span>
                <span>Pague com PIX — valor fica em escrow (seguro)</span>
            </div>
            <div class="check-item">
                <span class="ico"><i class="bi bi-3-circle"></i></span>
                <span>Montador homologado alocado em até 24h</span>
            </div>
            <a asp-page="/Projetos/Criar" asp-route-onboarding="true" class="btn btn-pc-accent btn-sm mt-2">
                Começar agora <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="pc-tile d-flex align-items-center gap-3">
                <div class="tile-icon" style="background:var(--pc-primary-soft);color:var(--pc-primary)"><i class="bi bi-folder"></i></div>
                <div><div class="tile-num">@Model.TotalProjetos</div><div class="tile-lbl">Projetos</div></div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="pc-tile d-flex align-items-center gap-3">
                <div class="tile-icon" style="background:var(--pc-warn-soft);color:var(--pc-warn)"><i class="bi bi-hourglass-split"></i></div>
                <div><div class="tile-num">@Model.AguardandoPagamento</div><div class="tile-lbl">Aguardando pagamento</div></div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="pc-tile d-flex align-items-center gap-3">
                <div class="tile-icon" style="background:var(--pc-success-soft);color:var(--pc-success)"><i class="bi bi-arrow-repeat"></i></div>
                <div><div class="tile-num">@Model.EmAndamento</div><div class="tile-lbl">Em andamento</div></div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="pc-tile d-flex align-items-center gap-3">
                <div class="tile-icon" style="background:var(--pc-info-soft);color:var(--pc-info)"><i class="bi bi-truck"></i></div>
                <div><div class="tile-num">@Model.TotalOrdens</div><div class="tile-lbl">Ordens de serviço</div></div>
            </div>
        </div>
    </div>

    <div class="pc-card mb-4" id="indiqueCard" style="background:linear-gradient(135deg,var(--pc-primary-soft),#fff);">
        <div class="pc-card-body d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div>
                <h5 class="fw-bold mb-1"><i class="bi bi-megaphone me-2"></i>Indique e fortaleça sua rede</h5>
                <p class="text-muted mb-0 small">
                    Conhece outro arquiteto que sofre com montagem? Compartilhe o PósCorte —
                    montagem com pagamento garantido, sem caçar marceneiro.
                </p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a id="btnWhats" class="btn btn-pc-primary btn-sm" target="_blank" rel="noopener">
                    <i class="bi bi-whatsapp me-1"></i>Compartilhar no WhatsApp
                </a>
                <button id="btnCopiar" type="button" class="btn btn-pc-ghost btn-sm">
                    <i class="bi bi-link-45deg me-1"></i><span>Copiar link</span>
                </button>
            </div>
        </div>
    </div>

    <div class="pc-card">
        <div class="pc-card-body d-flex justify-content-between align-items-center" style="padding-bottom:0">
            <h5 class="fw-bold mb-3">Projetos recentes</h5>
            <a asp-page="/Projetos/Index" class="small fw-semibold">Ver todos <i class="bi bi-arrow-right"></i></a>
        </div>
        @if (!Model.Projetos.Any())
        {
            <div class="pc-empty">
                <div class="icon"><i class="bi bi-inbox"></i></div>
                <p class="mt-2 mb-3">Você ainda não tem projetos.</p>
                <a asp-page="/Projetos/Criar" class="btn btn-pc-primary btn-sm">Criar primeiro projeto</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="pc-table">
                    <thead>
                        <tr><th>Projeto</th><th>Local</th><th>Peças / Gavetas</th><th>Status</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Projetos.OrderByDescending(x => x.Id).Take(8))
                        {
                            var (css, label) = UiHelper.StatusProjeto(p.StatusProjeto);
                            <tr>
                                <td class="fw-semibold">@p.NomeProjeto</td>
                                <td class="text-muted">@(string.IsNullOrEmpty(p.CepObra) ? "—" : p.CepObra)</td>
                                <td>@p.QtdPecas peças · @p.QtdGavetas gavetas</td>
                                <td><span class="pc-status @css">@label</span></td>
                                <td class="text-end">
                                    @if (p.StatusProjeto == "Aguardando_Pagamento")
                                    {
                                        <a asp-page="/Projetos/Pagar" asp-route-id="@p.Id" class="btn btn-pc-primary btn-sm me-1"><i class="bi bi-qr-code me-1"></i>Pagar</a>
                                    }
                                    <a asp-page="/Projetos/Detalhes" asp-route-id="@p.Id" class="btn btn-pc-ghost btn-sm">Detalhes</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var link = window.location.origin + "/Auth/Register";
            var msg = "Descobri o PósCorte: montagem de móveis planejados com orçamento na hora e pagamento garantido (escrow), sem precisar caçar marceneiro. Dá uma olhada: " + link;
            var whats = document.getElementById("btnWhats");
            if (whats) whats.href = "https://wa.me/?text=" + encodeURIComponent(msg);
            var btn = document.getElementById("btnCopiar");
            if (btn) {
                btn.addEventListener("click", function () {
                    navigator.clipboard.writeText(link).then(function () {
                        var span = btn.querySelector("span");
                        var antigo = span.textContent;
                        span.textContent = "Link copiado!";
                        setTimeout(function () { span.textContent = antigo; }, 2000);
                    });
                });
            }
        })();
    </script>
}

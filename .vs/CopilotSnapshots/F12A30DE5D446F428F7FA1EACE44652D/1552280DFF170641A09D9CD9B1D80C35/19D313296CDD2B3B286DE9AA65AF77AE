```csharp
using Microsoft.AspNetCore.Mvc;
using PosCorte.API.Data;
using PosCorte.API.Models;
using PosCorte.API.Services;
using Microsoft.EntityFrameworkCore;

namespace PosCorte.API.Controllers
{
    [ApiController]
    [Route("api/v1/projetos")]
    public class ProjetosController : ControllerBase
    {
        private readonly ApplicationDbContext _context;
        private readonly IPrecificacaoService _precificacaoService;

        public ProjetosController(ApplicationDbContext context, IPrecificacaoService precificacaoService)
        {
            _context = context;
            _precificacaoService = precificacaoService;
        }

        [HttpPost]
        public async Task<ActionResult<Projeto>> CriarProjeto([FromBody] Projeto projeto)
        {
            // Validar usuário
            var usuarioExists = await _context.Usuarios.AnyAsync(u => u.Id == projeto.UsuarioId);
            if (!usuarioExists)
                return BadRequest("Usuário não encontrado");

            _context.Projetos.Add(projeto);
            await _context.SaveChangesAsync();

            return CreatedAtAction(nameof(ObterProjeto), new { id = projeto.Id }, projeto);
        }

        [HttpPost("{id}/calcular-orcamento")]
        public ActionResult<OrcamentoResultado> CalcularOrcamento(int id, [FromBody] OrcamentoRequest request)
        {
            try
            {
                var resultado = _precificacaoService.ProcessarProjeto(request.QtdPecas, request.QtdGavetas);
                return Ok(resultado);
            }
            catch (ArgumentException ex)
            {
                return BadRequest(ex.Message);
            }
        }

        [HttpGet("{id}")]
        public async Task<ActionResult<Projeto>> ObterProjeto(int id)
        {
            var projeto = await _context.Projetos
                .Include(p => p.OrdensServico)
                .FirstOrDefaultAsync(p => p.Id == id);

            if (projeto == null)
                return NotFound();

            return Ok(projeto);
        }

        [HttpGet]
        public ActionResult<IEnumerable<Projeto>> ListarProjetos()
        {
            return Ok(_context.Projetos.ToList());
        }
    }

    public class OrcamentoRequest
    {
        public int QtdPecas { get; set; }
        public int QtdGavetas { get; set; }
    }
}
```

### 5.3 Controller de Webhooks (CRÍTICO)

**Criar arquivo:** `src/PosCorte.API/Controllers/WebhookPoscorteController.cs`

```csharp
using Microsoft.AspNetCore.Mvc;
using Microsoft.EntityFrameworkCore;
using PosCorte.API.Data;
using PosCorte.API.Models;
using PosCorte.API.Services;

namespace PosCorte.API.Controllers
{
    [ApiController]
    [Route("api/v1/webhooks/poscorte")]
    public class WebhookPoscorteController : ControllerBase
    {
        private readonly ApplicationDbContext _context;
        private readonly ILogger<WebhookPoscorteController> _logger;
        private readonly IPagamentoService _pagamentoService;
        private readonly IProvedorService _provedorService;

        public WebhookPoscorteController(
            ApplicationDbContext context, 
            ILogger<WebhookPoscorteController> logger,
            IPagamentoService pagamentoService,
            IProvedorService provedorService)
        {
            _context = context;
            _logger = logger;
            _pagamentoService = pagamentoService;
            _provedorService = provedorService;
        }

        [HttpPost("pagamento-confirmado")]
        public async Task<IActionResult> TratarPagamentoConfirmado([FromBody] WebhookPagamento dados)
        {
            _logger.LogInformation($"Webhook recebido: Projeto {dados.ProjetoId} - Status: {dados.Status}");

            try
            {
                var projeto = await _context.Projetos.FindAsync(dados.ProjetoId);
                if (projeto == null)
                    return NotFound("Projeto não encontrado");

                if (dados.Status == "pago")
                {
                    // TRAVA DE SEGURANÇA: Só cria ordem após pagamento confirmado
                    projeto.StatusProjeto = "Pagamento_Confirmado";

                    var request = new ProvedorService.ProvedorRequest
                    {
                        EnderecoCompleto = projeto.EnderecoCompleto,
                        Cep = projeto.CepObra,
                        DataAgendamento = DateTime.UtcNow.AddDays(1),
                        ValorTotal = 0, // Será calculado
                        UrlPlano = projeto.UrlArquivoCorteCloud
                    };

                    var provedorResponse = await _provedorService.CriarOrdemServicoAsync(request);

                    var ordem = new OrdemServico
                    {
                        ProjetoId = projeto.Id,
                        ExternalProviderId = provedorResponse.ExternalProviderId,
                        StatusProvedor = provedorResponse.Status,
                        MontadorNome = provedorResponse.MontadorNome,
                        MontadorTelefone = provedorResponse.MontadorTelefone
                    };

                    _context.OrdensServico.Add(ordem);
                    projeto.StatusProjeto = "Ordem_Criada";
                }

                await _context.SaveChangesAsync();
                return Ok(new { message = "Webhook processado com sucesso" });
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Erro ao processar webhook de pagamento");
                return StatusCode(500, new { error = ex.Message });
            }
        }

        [HttpPost("atualizacao-montador")]
        public async Task<IActionResult> TratarAtualizacaoMontador([FromBody] WebhookData dados)
        {
            _logger.LogInformation($"Webhook montador: ID {dados.IdExternalProviderId} - Status: {dados.Status}");

            try
            {
                var ordem = await _context.OrdensServico
                    .FirstOrDefaultAsync(o => o.ExternalProviderId == dados.IdExternalProviderId);

                if (ordem == null)
                    return NotFound("Ordem não encontrada");

                if (dados.Status == "aceito")
                {
                    ordem.StatusProvedor = "Prestador_Alocado";
                    ordem.MontadorNome = dados.NomeMontador;
                    ordem.MontadorTelefone = dados.TelefoneMontador;
                    ordem.MontadorFotoUrl = dados.FotoMontadorUrl;

                    var projeto = await _context.Projetos.FindAsync(ordem.ProjetoId);
                    projeto.StatusProjeto = "Prestador_Alocado";
                }
                else if (dados.Status == "concluido")
                {
                    ordem.StatusProvedor = "Concluido";
                    var projeto = await _context.Projetos.FindAsync(ordem.ProjetoId);
                    projeto.StatusProjeto = "Aguardando_Vistoria";

                    // ENCERRAMENTO POR DECURSO DE PRAZO: Agendar tarefa de liquidação em 72h
                    // TODO: Implementar agendador de tarefas (Hangfire/Quartz)
                }

                ordem.DataAtualizacao = DateTime.UtcNow;
                await _context.SaveChangesAsync();

                return Ok(new { message = "Atualização de montador processada" });
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Erro ao processar webhook de montador");
                return StatusCode(500, new { error = ex.Message });
            }
        }
    }

    public class WebhookPagamento
    {
        public int ProjetoId { get; set; }
        public string Status { get; set; }
        public string PixId { get; set; }
        public decimal Valor { get; set; }
    }
}

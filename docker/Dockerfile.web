FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS base
WORKDIR /app
EXPOSE 8080

FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src
COPY ["src/PosCorte.Web/PosCorte.Web.csproj", "src/PosCorte.Web/"]
RUN dotnet restore "src/PosCorte.Web/PosCorte.Web.csproj"
COPY . .
WORKDIR "/src/src/PosCorte.Web"
RUN dotnet build "PosCorte.Web.csproj" -c Release -o /app/build

FROM build AS publish
RUN dotnet publish "PosCorte.Web.csproj" -c Release -o /app/publish /p:UseAppHost=false

FROM base AS final
WORKDIR /app
COPY --from=publish /app/publish .
COPY docker/entrypoint-web.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
